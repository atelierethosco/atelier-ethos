---
// ============================================================
// Navbar.astro
// Üst navigasyon. Logo sol, menü ortası/sağı, CTA sağ uçta.
// Tasarım rehberi 6.bölüm — "Top navigation":
//  - Sticky DEĞİL (sayfa kaydırılınca kaybolur, StickyCTA devralır)
//  - Alt sınır: hairline ayrım
//  - Bileşik link grubu: Etkinlikler, Araçlar, Kaynaklar
//  - CTA: "Görüşme talep et" (ana sayfadaki #iletisim'e gider)
// ============================================================

const currentPath = Astro.url.pathname;

const links = [
  { href: '/etkinlikler', label: 'Etkinlikler' },
  { href: '/araclar', label: 'Araçlar' },
  { href: '/kaynaklar', label: 'Kaynaklar' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="ae-navbar">
  <div class="ae-container ae-navbar-inner">
    <a href="/" class="ae-navbar-brand" aria-label="Atelier Ethos ana sayfa">
      <img src="/LogoSS.png" alt="Atelier Ethos" />
    </a>

    <nav class="ae-navbar-links" aria-label="Ana navigasyon">
      {
        links.map((link) => (
          
            href={link.href}
            class:list={['ae-navbar-link', { 'is-active': isActive(link.href) }]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <a href="/#iletisim" class="ae-navbar-cta">Görüşme talep et</a>
  </div>
</header>

<style>
  .ae-navbar {
    background: var(--ae-white);
    border-bottom: 0.5px solid var(--ae-line);
    position: relative;
    z-index: 10;
  }

  .ae-navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 32px;
  }

  .ae-navbar-brand {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .ae-navbar-brand img {
    height: 36px;
    width: auto;
  }

  .ae-navbar-links {
    display: flex;
    align-items: center;
    gap: 32px;
    flex: 1;
    justify-content: center;
  }

  .ae-navbar-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--ae-ink);
    transition: color 0.2s ease;
    position: relative;
    padding: 4px 0;
  }

  .ae-navbar-link:hover {
    color: var(--ae-red);
  }

  .ae-navbar-link.is-active {
    color: var(--ae-red);
  }

  .ae-navbar-link.is-active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--ae-red);
  }

  .ae-navbar-cta {
    background: var(--ae-red);
    color: var(--ae-white);
    padding: 10px 22px;
    border-radius: var(--ae-radius-sm);
    font-size: 14px;
    font-weight: 500;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }

  .ae-navbar-cta:hover {
    background: var(--ae-red-hover);
  }

  /* Mobile — basit responsive (Tur 2'de mobile menu eklenebilir) */
  @media (max-width: 768px) {
    .ae-navbar-inner {
      height: 64px;
      gap: 16px;
    }

    .ae-navbar-brand img {
      height: 28px;
    }

    .ae-navbar-links {
      display: none;
    }

    .ae-navbar-cta {
      padding: 8px 16px;
      font-size: 13px;
    }
  }
</style>
