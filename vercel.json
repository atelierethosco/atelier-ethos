    { "source": "/webinar-on-soru.html", "destination": "/etkinlikler/yetkinlik-performans/on-soru", "permanent": true },
    { "source": "/webinar-yetkinlik-materyalleri.html", "destination": "/etkinlikler/yetkinlik-performans/materyaller", "permanent": true },
    { "source": "/yetkinlik-bazli-performans-kilavuzu.html", "destination": "/kaynaklar/performans/yetkinlik-bazli-kilavuz", "permanent": true },
